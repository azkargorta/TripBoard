# Supabase (obligatorio)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (recomendado; usado por Stripe/redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (obligatorio si usas Premium de pago)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=

# Asistente personal / LLM (opcional; necesario para funciones Premium del asistente)
# Provider: "gemini" | "ollama" (y otros si los añades)
AI_PROVIDER=gemini
AI_USER_MONTHLY_BUDGET_EUR=3.00
AI_ENHANCE_ANALYSIS=0

# Gemini (si AI_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Costes estimados (EUR por millón de tokens) para tracking/presupuesto
GEMINI_FLASH_INPUT_EUR_PER_M_TOKENS=
GEMINI_FLASH_OUTPUT_EUR_PER_M_TOKENS=

# Ollama (si AI_PROVIDER=ollama; normalmente solo local)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3

# OCR.Space (opcional; usado para análisis de documentos)
OCR_SPACE_API_KEY=

# Admin (opcional)
TRIPBOARD_ADMIN_EMAILS=

